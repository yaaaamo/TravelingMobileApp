<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F8">

    <!-- Hero header -->
    <LinearLayout
        android:id="@+id/heroHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:backgroundTint="@color/mainpink"/>

        <!-- Back row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF"
                android:background="@drawable/circle_white_translucent"
                android:padding="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Group"
                android:textColor="#FFDDE0"
                android:textSize="13sp"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

        <!-- Emoji avatar -->
        <TextView
            android:id="@+id/groupEmojiHero"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="👥"
            android:textSize="30sp"
            android:gravity="center"
            android:background="@drawable/hero_avatar_bg"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/groupName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/groupDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#FFDDE0"
            android:layout_marginBottom="14dp"/>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/memberCountChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="… members"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/chip_white_translucent"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/postCountChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="… photos"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/chip_white_translucent"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/routeCountChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="… paths"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/chip_white_translucent"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Actions card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="-14dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/addPostToGroupButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Add Post"
            android:backgroundTint="@color/mainpink"/>

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/addphoto"
                android:tint="@color/mainpink"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add photo"
                android:textSize="10sp"
                android:textColor="@color/mainpink"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/manageMembersButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Members"
            android:backgroundTint="@color/mainpink"/>

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/groups"
                android:tint="@color/mainpink"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Members"
                android:textSize="10sp"
                android:textColor="@color/mainpink"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/quitGroupButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/action_btn_red_bg"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/backarrow"
                android:tint="#E24B4A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leave"
                android:textSize="10sp"
                android:textColor="#E24B4A"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Tab buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/tabPhotos"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="📸 Photos"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/mainpink"
            style="@style/Widget.MaterialComponents.Button"/>

        <Button
            android:id="@+id/tabPaths"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="🗺 Paths"
            android:textSize="13sp"
            android:textColor="@color/mainpink"
            android:backgroundTint="#F5E8E8"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

    <!-- Photos tab content -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/groupPostsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:visibility="visible"/>

    <!-- Paths tab content -->
    <ScrollView
        android:id="@+id/pathsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/pathsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"/>

    </ScrollView>

</LinearLayout>