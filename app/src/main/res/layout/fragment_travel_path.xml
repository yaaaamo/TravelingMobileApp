<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFF8FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="15dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Préférences de voyage"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activités"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/check_restauration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restauration" />

        <CheckBox
            android:id="@+id/check_loisirs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loisirs" />

        <CheckBox
            android:id="@+id/check_decouvertes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Découvertes" />

        <CheckBox
            android:id="@+id/check_culture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Culture"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lieux favoris / obligatoires"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_places"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top|start"
            android:hint="Ex: Louvre, Tour Eiffel, Montmartre"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Budget max"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_budget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: 2500"
            android:inputType="numberDecimal"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Durée"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Durée (en heures)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: 6"
            android:inputType="number"
            android:layout_marginBottom="20dp" />

        <Spinner
            android:id="@+id/spinner_effort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tolérances météo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/check_cold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Froid" />

        <CheckBox
            android:id="@+id/check_heat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chaleur" />

        <CheckBox
            android:id="@+id/check_rain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pluie / humidité"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_save_preferences"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enregistrer les préférences" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/text_option_eco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_option_balanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_option_comfort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>